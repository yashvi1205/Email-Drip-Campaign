# -------------------------------------------------------------------------------
# EMAIL CAMPAIGN TRACKER - ENVIRONMENT CONFIGURATION (TEMPLATE)
# -------------------------------------------------------------------------------

# --- 1. CORE API SETTINGS ---
APP_ENV=development
DEBUG=true
PORT=8001

# --- 2. DATABASE CONFIGURATION ---
# Format: postgresql://user:pass@host:5321/dbname
DATABASE_URL=postgresql://winuser:password@localhost:5432/email_campaign
# DATABASE_URL=sqlite:///./email_campaign.db

# --- 3. REDIS CONFIGURATION (REQUIRED FOR QUEUE & RATE LIMITING) ---
REDIS_URL=redis://localhost:6379/0

# --- 4. BACKEND NETWORKING (PHASE 0) ---
# Used for internal callbacks from scraper to backend
# In Docker, use: http://backend:8001
# Local use: http://localhost:8001
BACKEND_INTERNAL_URL=http://localhost:8001

# --- 5. GOOGLE SHEETS INTEGRATION ---
# Path to your service account JSON file
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_SHEET_RANGE=Leads!A1:Z

# --- 6. SCRAPER CONFIGURATION ---
# Binary path for Chromium/Chrome (Optional)
# CHROME_BINARY_PATH=/usr/bin/chromium-browser
CHROME_PROFILE_BASE_PATH=./data/browser_profiles
LINKEDIN_PROFILE_NAME=default_profile
HEADLESS=true

# --- 7. EXTERNAL WEBHOOKS ---
N8N_WEBHOOK_URL=http://your-n8n-url/webhook/leads

# --- 8. SECURITY & RATE LIMITING ---
# Comma-separated list
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
SCRAPER_RATE_LIMIT_PER_MINUTE=5
TRACKING_RATE_LIMIT_PER_MINUTE=100
ADMIN_API_KEY=your_secure_admin_key_here
